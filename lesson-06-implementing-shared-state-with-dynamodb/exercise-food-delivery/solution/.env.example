# ─────────────────────────────────────────────────────────────────────────────
# Lesson 6 Exercise Solution: Shared State for Food Delivery
#
# Copy this file to .env and fill in your values.
# The .env file is gitignored — never commit real credentials.
#
# If you already deployed the stack while doing the starter (stack name
# lesson-06-exercise-shared-state), you don't need to deploy again — copy the
# same values from your starter's .env into this one to point at the same
# resources. Otherwise, deploy first:
#   aws cloudformation deploy --template-file infrastructure/stack.yaml \
#       --stack-name lesson-06-exercise-shared-state
# ─────────────────────────────────────────────────────────────────────────────

# ── AWS / Bedrock Settings ───────────────────────────────────────────────────
AWS_REGION=us-east-1
NOVA_LITE_MODEL=amazon.nova-lite-v1:0

# ── DynamoDB Table (from CloudFormation outputs) ─────────────────────────────
ORDER_STATE_TABLE=lesson-06-shared-state-order-state
