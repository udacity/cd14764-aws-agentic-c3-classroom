# ─────────────────────────────────────────────────────────────────────────────
# Lesson 6: Implementing Shared State with DynamoDB
#
# Copy this file to .env and fill in your values.
# The .env file is gitignored — never commit real credentials.
#
# Deploy infrastructure first:
#   aws cloudformation deploy --template-file infrastructure/stack.yaml \
#       --stack-name lesson-06-shared-state --capabilities CAPABILITY_NAMED_IAM
# ─────────────────────────────────────────────────────────────────────────────

# ── AWS / Bedrock Settings ───────────────────────────────────────────────────
AWS_REGION=us-east-1
NOVA_LITE_MODEL=amazon.nova-lite-v1:0

# ── DynamoDB Tables ──────────────────────────────────────────────────────────
# From CloudFormation outputs
TRIP_STATE_TABLE=lesson-06-shared-state-trip-state
ORDER_STATE_TABLE=lesson-06-shared-state-order-state
