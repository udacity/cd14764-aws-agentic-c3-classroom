# ─────────────────────────────────────────────────────────────────────────────
# Lesson 6 Demo: Shared State for Ride-Sharing
#
# Copy this file to .env and fill in your values.
# The .env file is gitignored — never commit real credentials.
#
# Deploy infrastructure first (creates the DynamoDB trip-state table):
#   aws cloudformation deploy --template-file infrastructure/stack.yaml \
#       --stack-name lesson-06-demo-shared-state
# ─────────────────────────────────────────────────────────────────────────────

# ── AWS / Bedrock Settings ───────────────────────────────────────────────────
AWS_REGION=us-east-1
NOVA_LITE_MODEL=amazon.nova-lite-v1:0

# ── DynamoDB Table (from CloudFormation outputs) ─────────────────────────────
TRIP_STATE_TABLE=lesson-06-shared-state-trip-state
