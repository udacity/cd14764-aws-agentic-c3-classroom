# ─────────────────────────────────────────────────────────────────────────────
# Lesson 7 Exercise Solution: Saga Pattern for E-Commerce Checkout
#
# Copy this file to .env and fill in your values.
# The .env file is gitignored — never commit real credentials.
#
# If you already deployed the stack while doing the starter (stack name
# lesson-07-exercise-saga), you don't need to deploy again — copy the same
# values from your starter's .env into this one to point at the same resources.
# Otherwise, deploy first:
#   aws cloudformation deploy --template-file infrastructure/stack.yaml \
#       --stack-name lesson-07-exercise-saga
# ─────────────────────────────────────────────────────────────────────────────

# ── AWS Credentials (from the "Load AWS Credentials" sidebar) ────────────────
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_SESSION_TOKEN=your-session-token

# ── AWS / Bedrock Settings ───────────────────────────────────────────────────
AWS_REGION=us-west-1
NOVA_LITE_MODEL=us.amazon.nova-lite-v1:0

# ── DynamoDB Table (from CloudFormation outputs) ─────────────────────────────
CHECKOUT_SAGA_TABLE=lesson-07-saga-checkout-saga
