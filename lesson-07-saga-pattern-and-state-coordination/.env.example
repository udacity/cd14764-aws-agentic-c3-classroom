# ─────────────────────────────────────────────────────────────────────────────
# Lesson 7: Saga Pattern and State Coordination
#
# Copy this file to .env and fill in your values.
# The .env file is gitignored — never commit real credentials.
#
# Deploy infrastructure first:
#   aws cloudformation deploy --template-file infrastructure/stack.yaml \
#       --stack-name lesson-07-saga --capabilities CAPABILITY_NAMED_IAM
# ─────────────────────────────────────────────────────────────────────────────

# ── AWS / Bedrock Settings ───────────────────────────────────────────────────
AWS_REGION=us-east-1
NOVA_LITE_MODEL=amazon.nova-lite-v1:0

# ── DynamoDB Tables ──────────────────────────────────────────────────────────
# From CloudFormation outputs
SAGA_STATE_TABLE=lesson-07-saga-saga-state
CHECKOUT_SAGA_TABLE=lesson-07-saga-checkout-saga
