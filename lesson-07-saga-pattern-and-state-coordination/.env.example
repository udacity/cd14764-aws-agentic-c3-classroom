# ─────────────────────────────────────────────────────────────────────────────
# Lesson 7: Saga Pattern and State Coordination
#
# Setup steps:
#   1. Copy this file to .env:
#        cp .env.example .env
#   2. Fill in your AWS credentials below (from the classroom AWS gateway).
#   3. Set AWS_REGION to match the region shown in your classroom console
#      (commonly us-west-1 or us-west-2 in Udacity environments).
#   4. Deploy the infrastructure via the AWS Console:
#        CloudFormation → Create stack → Upload infrastructure/stack.yaml
#        Stack name: lesson-07-saga
#      Or with Python (if no AWS CLI):
#        python3 -c "
#        import boto3, os; from dotenv import load_dotenv; load_dotenv()
#        cf = boto3.client('cloudformation', region_name=os.environ['AWS_REGION'])
#        cf.create_stack(StackName='lesson-07-saga', TemplateBody=open('infrastructure/stack.yaml').read())
#        print('Stack creation started')
#        "
#
# The .env file is gitignored — never commit real credentials.
# ─────────────────────────────────────────────────────────────────────────────

# ── AWS Credentials ──────────────────────────────────────────────────────────
# Get these from the classroom AWS gateway (they expire after a few hours).
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_SESSION_TOKEN=your-session-token

# ── AWS / Bedrock Settings ───────────────────────────────────────────────────
# Set AWS_REGION to match the region where you deployed the CloudFormation stack.
# Use the cross-region inference profile prefix (us.) for Nova models —
# on-demand throughput requires an inference profile, not a bare model ID.
AWS_REGION=us-west-1
NOVA_LITE_MODEL=us.amazon.nova-lite-v1:0

# ── DynamoDB Tables ──────────────────────────────────────────────────────────
# These names match the CloudFormation stack. Only change if you used a
# different stack name or ProjectName parameter.
SAGA_STATE_TABLE=lesson-07-saga-saga-state
CHECKOUT_SAGA_TABLE=lesson-07-saga-checkout-saga
