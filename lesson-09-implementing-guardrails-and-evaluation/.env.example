# ─────────────────────────────────────────────────────────────────────────────
# Lesson 9: Implementing Guardrails and Evaluation
#
# Copy this file to .env and fill in your values.
# The .env file is gitignored — never commit real credentials.
#
# Deploy infrastructure first:
#   aws cloudformation deploy --template-file infrastructure/stack.yaml \
#       --stack-name lesson-stack --capabilities CAPABILITY_NAMED_IAM
# ─────────────────────────────────────────────────────────────────────────────

# ── AWS / Bedrock Settings ───────────────────────────────────────────────────
AWS_REGION=us-east-1
NOVA_LITE_MODEL=us.amazon.nova-lite-v1:0

# ── Bedrock Guardrails (from CloudFormation outputs) ─────────────────────────
HEALTHCARE_GUARDRAIL_ID=
HEALTHCARE_GUARDRAIL_VERSION=DRAFT
TRADING_GUARDRAIL_ID=
TRADING_GUARDRAIL_VERSION=DRAFT

# ── Kill Switch Configuration ────────────────────────────────────────────────
KILL_SWITCH_THRESHOLD=3
KILL_SWITCH_WINDOW_SECONDS=300

# ── Model Evaluation ─────────────────────────────────────────────────────────
EVAL_MODEL=us.anthropic.claude-sonnet-4-5-20250929-v1:0
