# ─────────────────────────────────────────────────────────────────────────────
# Lesson 9 Demo: Healthcare Agent Guardrails
#
# Copy this file to .env and fill in your values.
# The .env file is gitignored — never commit real credentials.
#
# Deploy infrastructure first (creates the Bedrock Healthcare Guardrail in us-east-1):
#   aws cloudformation deploy --template-file infrastructure/stack.yaml \
#       --stack-name lesson-09-demo-guardrails
#
# After deploy, copy HealthcareGuardrailId from the stack Outputs into
# HEALTHCARE_GUARDRAIL_ID below (use the short ID, not the full ARN).
# ─────────────────────────────────────────────────────────────────────────────

# ── AWS / Bedrock Settings ───────────────────────────────────────────────────
# Bedrock Guardrails require us-east-1 in this lesson.
AWS_REGION=us-east-1
NOVA_LITE_MODEL=us.amazon.nova-lite-v1:0

# ── Bedrock Guardrail (from CloudFormation outputs) ──────────────────────────
HEALTHCARE_GUARDRAIL_ID=
HEALTHCARE_GUARDRAIL_VERSION=DRAFT

# ── Kill Switch Configuration ────────────────────────────────────────────────
KILL_SWITCH_THRESHOLD=3
KILL_SWITCH_WINDOW_SECONDS=300

# ── Model Evaluation ─────────────────────────────────────────────────────────
EVAL_MODEL=us.anthropic.claude-sonnet-4-20250514-v1:0
