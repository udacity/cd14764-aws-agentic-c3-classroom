# ─────────────────────────────────────────────────────────────────────────────
# Lesson 5 Demo: Hybrid Router for Financial Transactions
#
# Copy this file to .env and fill in your values.
# The .env file is gitignored — never commit real credentials.
#
# Deploy infrastructure first (creates the DynamoDB routing-audit table):
#   aws cloudformation deploy --template-file infrastructure/stack.yaml \
#       --stack-name lesson-05-demo-routing
# ─────────────────────────────────────────────────────────────────────────────

# ── AWS / Bedrock Settings ───────────────────────────────────────────────────
AWS_REGION=us-east-1
NOVA_LITE_MODEL=amazon.nova-lite-v1:0

# ── DynamoDB Table (from CloudFormation outputs) ─────────────────────────────
ROUTING_AUDIT_TABLE=lesson-05-demo-routing-audit
