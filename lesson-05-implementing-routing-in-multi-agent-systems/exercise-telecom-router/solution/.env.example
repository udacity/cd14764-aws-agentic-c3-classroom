# ─────────────────────────────────────────────────────────────────────────────
# Lesson 5 Exercise Solution: Multi-Strategy Router for Telecom Tickets
#
# Copy this file to .env and fill in your values.
# The .env file is gitignored — never commit real credentials.
#
# If you already deployed the stack while doing the starter (stack name
# lesson-05-exercise-routing), you don't need to deploy again — copy the same
# values from your starter's .env into this one. Otherwise:
#   aws cloudformation deploy --template-file infrastructure/stack.yaml \
#       --stack-name lesson-05-exercise-routing
# ─────────────────────────────────────────────────────────────────────────────

# ── AWS / Bedrock Settings ───────────────────────────────────────────────────
AWS_REGION=us-east-1
NOVA_LITE_MODEL=amazon.nova-lite-v1:0

# ── DynamoDB Table (from CloudFormation outputs) ─────────────────────────────
ROUTING_AUDIT_TABLE=lesson-05-exercise-routing-audit
