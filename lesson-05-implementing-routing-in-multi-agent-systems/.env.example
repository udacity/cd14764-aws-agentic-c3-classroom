# ─────────────────────────────────────────────────────────────────────────────
# Lesson 5: Implementing Routing in Multi-Agent Systems
#
# Copy this file to .env and fill in your values.
# The .env file is gitignored — never commit real credentials.
#
# Deploy infrastructure first:
#   aws cloudformation deploy --template-file infrastructure/stack.yaml \
#       --stack-name lesson-05-routing
# ─────────────────────────────────────────────────────────────────────────────

# ── AWS / Bedrock Settings ───────────────────────────────────────────────────
AWS_REGION=us-east-1
NOVA_LITE_MODEL=amazon.nova-lite-v1:0

# ── DynamoDB ─────────────────────────────────────────────────────────────────
# Table name created by CloudFormation (infrastructure/stack.yaml)
ROUTING_AUDIT_TABLE=lesson-05-routing-routing-audit
