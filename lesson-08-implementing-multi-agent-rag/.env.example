# ─────────────────────────────────────────────────────────────────────────────
# Lesson 8: Implementing Multi-Agent RAG
#
# Copy this file to .env and fill in your values.
# The .env file is gitignored — never commit real credentials.
#
# Setup steps:
#   1. Deploy S3 bucket:
#      aws cloudformation deploy --template-file infrastructure/stack.yaml \
#          --stack-name lesson-08-rag
#   2. Upload documents to S3 (see seed_documents.py)
#   3. Create Knowledge Bases in AWS Console:
#      Bedrock → Knowledge Bases → Create
#      Use S3 bucket from step 1 as data source
#      Embedding model: amazon.titan-embed-text-v2:0
#   4. Copy KB IDs below
# ─────────────────────────────────────────────────────────────────────────────

# ── AWS / Bedrock Settings ───────────────────────────────────────────────────
AWS_REGION=us-east-1
NOVA_LITE_MODEL=us.amazon.nova-lite-v1:0
NOVA_PRO_MODEL=us.amazon.nova-pro-v1:0

# ── S3 Bucket (from CloudFormation) ──────────────────────────────────────────
KB_SOURCE_BUCKET=lesson-08-rag-kb-sources-ACCOUNT_ID

# ── Demo Knowledge Base IDs (create manually in AWS Console) ─────────────────
CS_KB_ID=
BIO_KB_ID=

# ── Exercise Knowledge Base IDs (create manually in AWS Console) ─────────────
DRUG_INTERACTIONS_KB_ID=
CLINICAL_GUIDELINES_KB_ID=
