# ─────────────────────────────────────────────────────────────────────────────
# Lesson 11: Inter-Agent Communication via Gateway
#
# Copy this file to .env and fill in your values.
# The .env file is gitignored — never commit real credentials.
#
# Deploy infrastructure first:
#   aws cloudformation deploy --template-file infrastructure/stack.yaml \
#       --stack-name lesson-11-gateway --capabilities CAPABILITY_NAMED_IAM
# ─────────────────────────────────────────────────────────────────────────────

# ── AWS / Bedrock Settings ───────────────────────────────────────────────────
AWS_REGION=us-east-1
NOVA_LITE_MODEL=amazon.nova-lite-v1:0

# ── Demo: Supply Chain Gateway Lambda Function Names ────────────────────────
INVENTORY_FUNCTION=lesson-11-gateway-inventory
SHIPPING_FUNCTION=lesson-11-gateway-shipping
SUPPLIER_FUNCTION=lesson-11-gateway-supplier
QUALITY_INSPECTION_FUNCTION=lesson-11-gateway-quality-inspection

# ── Exercise: Analytics Gateway Lambda Function Names ──────────────────────
WEATHER_FUNCTION=lesson-11-gateway-weather
CURRENCY_FUNCTION=lesson-11-gateway-currency
NEWS_FUNCTION=lesson-11-gateway-news
