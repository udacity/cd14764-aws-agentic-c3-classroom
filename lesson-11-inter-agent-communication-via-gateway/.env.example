# ─────────────────────────────────────────────────────────────────────────────
# Lesson 11: Inter-Agent Communication via Gateway
#
# Copy this file to .env and fill in your values.
# The .env file is gitignored — never commit real credentials.
#
# Step 1: Paste AWS credentials from the Udacity lab sidebar.
# Step 2: Run infrastructure/deploy_stack.py — it prints AGENTCORE_ROLE_ARN.
# Step 3: Paste that role ARN below.
# ─────────────────────────────────────────────────────────────────────────────

# ── AWS Credentials (from Udacity lab sidebar "Load AWS Credentials") ────────
AWS_ACCESS_KEY_ID=PASTE_YOUR_ACCESS_KEY_ID_HERE
AWS_SECRET_ACCESS_KEY=PASTE_YOUR_SECRET_ACCESS_KEY_HERE
AWS_SESSION_TOKEN=PASTE_YOUR_SESSION_TOKEN_HERE

# ── AWS / Bedrock Settings ───────────────────────────────────────────────────
AWS_REGION=us-east-1
NOVA_LITE_MODEL=amazon.nova-lite-v1:0

# ── AgentCore Gateway Role (from deploy_stack.py output) ────────────────────
# Printed when you run: python infrastructure/deploy_stack.py
AGENTCORE_ROLE_ARN=PASTE_YOUR_AGENTCORE_ROLE_ARN_HERE

# ── Demo: Supply Chain Gateway Lambda Function Names ────────────────────────
INVENTORY_FUNCTION=lesson-11-gateway-inventory
SHIPPING_FUNCTION=lesson-11-gateway-shipping
SUPPLIER_FUNCTION=lesson-11-gateway-supplier
QUALITY_INSPECTION_FUNCTION=lesson-11-gateway-quality-inspection

# ── Exercise: Analytics Gateway Lambda Function Names ──────────────────────
WEATHER_FUNCTION=lesson-11-gateway-weather
CURRENCY_FUNCTION=lesson-11-gateway-currency
NEWS_FUNCTION=lesson-11-gateway-news
