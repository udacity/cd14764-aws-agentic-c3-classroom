# ─────────────────────────────────────────────────────────────────────────────
# Lesson 10: Production Deployment and Monitoring
#
# Copy this file to .env and fill in your values.
# The .env file is gitignored — never commit real credentials.
# ─────────────────────────────────────────────────────────────────────────────

# ── AWS Credentials ──────────────────────────────────────────────────────────
# In the Udacity lab: click "Load AWS Credentials" in the sidebar,
# then copy the three values shown there into this file.
AWS_ACCESS_KEY_ID=PASTE_YOUR_ACCESS_KEY_ID_HERE
AWS_SECRET_ACCESS_KEY=PASTE_YOUR_SECRET_ACCESS_KEY_HERE
AWS_SESSION_TOKEN=PASTE_YOUR_SESSION_TOKEN_HERE

# ── Region ───────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1

# ── Infrastructure ──────────────────────────────────────────────────────────
# Role ARN and S3 bucket are auto-discovered from CloudFormation exports
# after running: python infrastructure/deploy_stack.py
# No manual values needed here.

# ── Guardrail ───────────────────────────────────────────────────────────────
# Use the guardrail you created in Lesson 9.
# Find it in the AWS Console → Bedrock → Guardrails.
# Tip: check the Lesson 9 output — it printed your guardrail ID when created.
GUARDRAIL_ID=PASTE_YOUR_GUARDRAIL_ID_HERE
GUARDRAIL_VERSION=DRAFT
