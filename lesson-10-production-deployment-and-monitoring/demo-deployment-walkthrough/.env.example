# ─────────────────────────────────────────────────────────────────────────────
# Lesson 10 Demo: Production Deployment and Monitoring (Insurance Claims)
#
# Copy this file to .env and fill in your values.
# The .env file is gitignored — never commit real credentials.
#
# Heads up: this lesson only requires you to fill in AWS credentials below.
# The IAM role, S3 artifact bucket, and Bedrock guardrail IDs are NOT pasted
# here — at startup, the demo calls `_load_cf_exports()` which queries the
# CloudFormation API for every export in your region and picks the three IDs
# by their export names (e.g. `lesson-10-demo-AgentCoreRoleArn`). Your AWS
# credentials are what unlock that lookup.
# ─────────────────────────────────────────────────────────────────────────────

# ── AWS Credentials (from Udacity lab sidebar "Load AWS Credentials") ────────
AWS_ACCESS_KEY_ID=PASTE_YOUR_ACCESS_KEY_ID_HERE
AWS_SECRET_ACCESS_KEY=PASTE_YOUR_SECRET_ACCESS_KEY_HERE
AWS_SESSION_TOKEN=PASTE_YOUR_SESSION_TOKEN_HERE

# ── Region ───────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
