# ─────────────────────────────────────────────────────────────────────────────
# Udacity AgentCore Project - Environment Variables
#
# Copy this file to .env and fill in your values.
# The .env file is gitignored - never commit real IDs.
#
# Most AWS resource names/ARNs are loaded automatically from CloudFormation
# exports. Only values that cannot be auto-discovered go here.
# ─────────────────────────────────────────────────────────────────────────────

# ── AWS Settings ──────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
PROJECT_NAME=udacity-agentcore

# ── Bedrock Knowledge Base IDs (Task 5) ───────────────────────────────────────
# Create these manually in the AWS Console:
#   Bedrock → Knowledge Bases → Create Knowledge Base
#   Use S3 prefix  policies/returns/   for RETURNS_KB_ID
#   Use S3 prefix  policies/shipping/  for SHIPPING_KB_ID
#   Use S3 prefix  policies/warranty/  for WARRANTY_KB_ID
#   Embedding model: amazon.titan-embed-text-v2:0
#   Vector store:    S3 Vectors (use the VectorStoreBucket from CloudFormation)
RETURNS_KB_ID=
SHIPPING_KB_ID=
WARRANTY_KB_ID=

# ── AgentCore Runtime (Task 3) ────────────────────────────────────────────────
# Populated automatically by:  python src/agent_orchestrator.py deploy
AGENTCORE_RUNTIME_ARN=

# ── Guardrail (Task 3) ────────────────────────────────────────────────────────
# Populated automatically by the deploy command above.
GUARDRAIL_ID=
GUARDRAIL_VERSION=DRAFT
